{
  "version": 2,
  "rewrites": [
    { "source": "/api/register", "destination": "/backend/api/register.js" },
    { "source": "/api/login", "destination": "/backend/api/login.js" },
    { "source": "/api/user", "destination": "/backend/api/user.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
