{
  "version": 2,
  "builds": [
    {
      "src": "backend/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/api/register", "destination": "/backend/register.js" },
    { "source": "/api/login", "destination": "/backend/login.js" },
    { "source": "/api/user", "destination": "/backend/user.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
